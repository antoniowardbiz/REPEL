# ── Database ────────────────────────────────────────────────────────────────
# Phase 1 default: SQLite (zero-config, runs anywhere).
DATABASE_URL="file:./dev.db"
# To switch to Postgres / Supabase later, change prisma/schema.prisma datasource
# provider to "postgresql" and set, e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/swift?schema=public"

# ── Telegram bot (optional in Phase 1) ──────────────────────────────────────
# Get a token from @BotFather. If unset, outbound messages are recorded as
# "simulated" so the whole pipeline is testable without a live bot.
TELEGRAM_BOT_TOKEN=""
# The bot's @username (no @), e.g. Swift_ofm_Bot. Powers the /start deep-link
# (t.me/<username>?start=<token>) so a new applicant's first-touch can be sent
# the instant they tap it (Telegram bots can't DM someone who hasn't started them).
TELEGRAM_BOT_USERNAME=""
# Shared secret appended to the webhook URL to authenticate Telegram callbacks.
TELEGRAM_WEBHOOK_SECRET="change-me"

# ── Internal ops alerts (optional) ──────────────────────────────────────────
# Slack incoming webhook OR a Telegram ops chat id. Leave blank to disable.
SLACK_WEBHOOK_URL=""
OPS_TELEGRAM_CHAT_ID=""

# ── Claude API (AI scoring assist + AI support agent) ───────────────────────
# Set an Anthropic API key to enable BOTH:
#  - the "🤖 AI draft" button on the scoring screen, and
#  - the 24/7 AI support agent in the Telegram bot: it answers candidate
#    questions from their real pipeline context (role, stage, model, drive,
#    deadline, pay) and escalates anything sensitive to the ops channel.
# Unset → both features are off; the rest of the pipeline is unaffected.
ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-opus-4-8). Use claude-sonnet-5 or
# claude-haiku-4-5 to trade capability for lower cost.
ANTHROPIC_MODEL=""
# AI support agent switches: set AI_SUPPORT=0 to disable just the bot agent;
# AI_SUPPORT_MAX_PER_DAY caps AI replies per candidate per day (default 15).
AI_SUPPORT="1"
AI_SUPPORT_MAX_PER_DAY="15"

# ── Scheduler (in-process; Railway needs no external cron) ──────────────────
# The app runs its own recurring jobs on boot. Tune the once-a-day jobs:
TZ_OFFSET="8"        # hours from UTC for "local" time (PH = +8)
MORNING_HOUR="8"     # local hour to DM VAs their morning message
DIGEST_HOUR="21"     # local hour to send the operator daily digest
# DISABLE_SCHEDULER="1"   # set to turn the in-process scheduler off

# ── Cron (OPTIONAL backup / external trigger for the same jobs) ──────────────
# Shared secret for the /api/cron/* endpoints. Pass as ?secret=... or the
# x-cron-secret header. In dev (NODE_ENV!=production) cron is open if unset.
CRON_SECRET="change-me-cron"

# ── Apify (OPTIONAL — flip on richer IG/X trial-watching, costs per run) ─────
# Without it the watcher uses Reddit's free API + activity-based scoring.
APIFY_TOKEN=""

# ── Mass-hire automation ────────────────────────────────────────────────────
# When ON (default), every candidate who SUBMITS their trial is hired on the
# spot — onboarded, offer sent, moved to ACTIVE — with no score gate and no
# rejections. Scoring still runs (to flag who needs extra training) but never
# blocks a hire. Set to "0" for the classic score-gated flow.
AUTO_HIRE="1"

# ── App ─────────────────────────────────────────────────────────────────────
# Public base URL, used to build the apply-form link shared in OLJ replies.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
