// SWIFT — VA Recruitment, Trial, Scoring & Onboarding System
// Phase 1 (MVP) data model.
//
// DB: SQLite for zero-config local/dev. The schema is intentionally
// Postgres-compatible: to move to Postgres/Supabase, change `provider` to
// "postgresql", point DATABASE_URL at the Postgres URL, and (optionally)
// promote the String JSON columns to `Json`/jsonb. SQLite has no native
// enums, so status/stage/tier values are Strings validated in app code
// (see src/lib/constants.ts).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Creators / models
// ─────────────────────────────────────────────────────────────────────────────
model Creator {
  id              String   @id @default(cuid())
  name            String
  niche           String?
  personaNotes    String?
  xMainUrl        String?
  igHandle        String?
  tiktokHandle    String?
  contentDriveUrl String? // general/fallback drive
  contentDrives   String? // JSON {roleKey: driveUrl} — per-role drives (e.g. x_va vs reddit_va content)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rolesAsDefault Role[]           @relation("RoleDefaultCreator")
  trials         Trial[]
  assignments    Assignment[]
  telegramGroups TelegramGroup[]
  accounts       Account[]
  managers       CreatorManager[]
}

// Which managers oversee which models (many-to-many). A model can have several
// managers and a manager can cover several models.
model CreatorManager {
  id        String   @id @default(cuid())
  creatorId String
  userId    String
  createdAt DateTime @default(now())

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([creatorId, userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Roles (the six VA roles). One Rubric per role; templates resolved by category.
// ─────────────────────────────────────────────────────────────────────────────
model Role {
  id               String   @id @default(cuid())
  key              String   @unique // x_va | tiktok_va | ig_manager | ig_dm_handler | video_editor | reddit_va
  displayName      String
  trialHours       Int      @default(24)
  capacity         Int? // target headcount; when the role's active funnel hits this it "closes" on the apply form (null = unlimited)
  trainingGroupUrl String?
  defaultCreatorId String?
  managerUserId    String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  defaultCreator Creator?          @relation("RoleDefaultCreator", fields: [defaultCreatorId], references: [id])
  manager        User?             @relation("RoleManager", fields: [managerUserId], references: [id])
  rubric         Rubric?
  trainingModule TrainingModule?
  templates      MessageTemplate[]
  applications   Application[]
  candidates     Candidate[]       @relation("CandidateCurrentRole")
  assignments    Assignment[]
  telegramGroups TelegramGroup[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Candidates → become Users on hire
// ─────────────────────────────────────────────────────────────────────────────
model Candidate {
  id             String   @id @default(cuid())
  fullName       String
  telegramHandle String?
  telegramChatId String? // numeric chat id once the candidate DMs the bot
  email          String?
  source         String   @default("onlinejobs_ph")
  timezone       String?
  country        String?
  whyText        String? // their "why this role"
  notes          String?
  currentStage   String   @default("APPLIED")
  currentRoleId  String?
  startToken     String?  @unique // deep-link token: t.me/<bot>?start=<startToken>
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  currentRole      Role?             @relation("CandidateCurrentRole", fields: [currentRoleId], references: [id])
  applications     Application[]
  messages         Message[]
  hiredUser        User?             @relation("CandidateToUser")
  groupMemberships GroupMembership[]
  activityEvents   ActivityEvent[]
  quizAttempts     QuizAttempt[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Application — one per (candidate, role) attempt; drives the state machine
// ─────────────────────────────────────────────────────────────────────────────
model Application {
  id             String   @id @default(cuid())
  candidateId    String
  roleId         String
  whyText        String?
  stage          String   @default("APPLIED")
  appliedAt      DateTime @default(now())
  stageChangedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id])
  trials    Trial[]
  messages  Message[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Trial — the 24h task the candidate runs
// ─────────────────────────────────────────────────────────────────────────────
model Trial {
  id              String    @id @default(cuid())
  applicationId   String
  creatorId       String?
  contentDriveUrl String?
  accountUsed     String?
  briefSentAt     DateTime?
  startedAt       DateTime?
  deadlineAt      DateTime?
  submissionUrls  String    @default("[]") // JSON array of links
  submittedAt     DateTime?
  status          String    @default("not_started") // not_started | active | submitted | expired
  remind12hSent   Boolean   @default(false)
  remind2hSent    Boolean   @default(false)
  managerNudgeSent Boolean  @default(false) // one-time nudge for a stalled managed (Reddit) account step
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  creator     Creator?    @relation(fields: [creatorId], references: [id])
  scoreCard   ScoreCard?
  watch       TrialWatch?
}

// ─────────────────────────────────────────────────────────────────────────────
// Rubric — one per role; criteria is a JSON array of weighted, anchored items
// ─────────────────────────────────────────────────────────────────────────────
model Rubric {
  id        String   @id @default(cuid())
  roleId    String   @unique
  name      String
  criteria  String // JSON: [{key,label,weight,anchor_5,anchor_3,anchor_1}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// ScoreCard — the finalized (or draft) score for a trial
// ─────────────────────────────────────────────────────────────────────────────
model ScoreCard {
  id            String    @id @default(cuid())
  trialId       String    @unique
  scorerUserId  String?
  aiDraft       String? // JSON {scores, rationale, flags, suggested_tier}
  scores        String    @default("{}") // JSON {criterion_key: 0-5}
  flags         String    @default("[]") // JSON array of hard-fail flag keys
  weightedTotal Float     @default(0)
  autoRating    Int? // watcher-derived 1–10 rating
  tier          String? // A | B | C | REJECT
  rationale     String?
  finalized     Boolean   @default(false)
  scoredAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trial  Trial @relation(fields: [trialId], references: [id], onDelete: Cascade)
  scorer User? @relation(fields: [scorerUserId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// Message templates (Telegram). Resolved by (roleId, category).
// ─────────────────────────────────────────────────────────────────────────────
model MessageTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  roleId    String?
  channel   String   @default("telegram")
  category  String   @default("other") // first_touch | brief | offer | retrial | decline | training | other
  subject   String?
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role Role? @relation(fields: [roleId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// Users (staff). A Candidate becomes a User on hire.
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  name           String
  role           String   @default("va") // admin | manager | va
  telegramHandle String?
  email          String?
  payRate        String?
  paymentMethod  String?
  status         String   @default("active")
  candidateId    String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fromCandidate Candidate?   @relation("CandidateToUser", fields: [candidateId], references: [id])
  managedRoles  Role[]       @relation("RoleManager")
  managesModels CreatorManager[]
  scoreCards    ScoreCard[]
  assignments   Assignment[] @relation("UserAssignments")
  accessGrants  AccessGrant[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Message log (candidate comms history)
// ─────────────────────────────────────────────────────────────────────────────
model Message {
  id            String   @id @default(cuid())
  candidateId   String
  applicationId String?
  direction     String   @default("outbound") // outbound | inbound
  channel       String   @default("telegram")
  templateKey   String?
  body          String
  status        String   @default("sent") // sent | simulated | failed | received
  meta          String?
  createdAt     DateTime @default(now())

  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  application Application?  @relation(fields: [applicationId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// Lightweight ops tables
// ─────────────────────────────────────────────────────────────────────────────
model Notification {
  id        String    @id @default(cuid())
  type      String
  payload   String?
  channel   String    @default("ops")
  status    String    @default("pending")
  createdAt DateTime  @default(now())
  sentAt    DateTime?
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String
  meta        String?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2 — assignments / distribution, Telegram "folders", trial watcher
// ─────────────────────────────────────────────────────────────────────────────

// A hired VA assigned to a model (creator) under a role. Drives even distribution.
model Assignment {
  id            String   @id @default(cuid())
  userId        String
  creatorId     String
  roleId        String
  managerUserId String?
  startDate     DateTime @default(now())
  status        String   @default("probation") // probation | active | ended
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation("UserAssignments", fields: [userId], references: [id])
  creator Creator @relation(fields: [creatorId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  // NOTE: a PARTIAL unique index on (userId, roleId) WHERE status IN
  // ('probation','active') is enforced via migration
  // 20260702110000_assignment_unique_active (SQLite partial indexes can't be
  // expressed in the Prisma schema). It blocks duplicate ACTIVE assignments
  // while still allowing re-assignment after an old one has 'ended'.
}

// A Telegram group that acts as a "folder" (Bot API can't manage real chat
// folders, so each folder = a group with a shareable invite link). Resolved by
// (role, kind, creator): e.g. "X VA – Trial" (kind=trial) or "X VA – Lae"
// (kind=qualified, creator=Lae).
model TelegramGroup {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  roleId    String?
  creatorId String?
  kind      String   @default("general") // trial | qualified | training | general
  inviteUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role        Role?             @relation(fields: [roleId], references: [id])
  creator     Creator?          @relation(fields: [creatorId], references: [id])
  memberships GroupMembership[]
}

// Tracks which "folder"/group a candidate has been routed into. Bot API can't
// confirm joins, so status starts "invited" and is advanced on confirmation.
model GroupMembership {
  id          String    @id @default(cuid())
  groupId     String
  candidateId String
  status      String    @default("invited") // invited | joined | removed
  invitedAt   DateTime  @default(now())
  joinedAt    DateTime?
  removedAt   DateTime?

  group     TelegramGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  candidate Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([groupId, candidateId])
}

// A watcher monitoring a trial account over its 24h window.
model TrialWatch {
  id            String    @id @default(cuid())
  trialId       String    @unique
  platform      String // x | instagram | reddit | tiktok
  accountHandle String?
  source        String    @default("activity") // reddit | activity | apify
  status        String    @default("active") // active | stopped
  intervalMins  Int       @default(60)
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trial        Trial              @relation(fields: [trialId], references: [id], onDelete: Cascade)
  observations TrialObservation[]
}

// A single watcher reading: metrics captured at a point in time.
model TrialObservation {
  id         String   @id @default(cuid())
  watchId    String
  trialId    String
  source     String
  capturedAt DateTime @default(now())
  metrics    String   @default("{}") // JSON: {posts, cadenceMins, removed, karma, ...}
  notes      String?

  watch TrialWatch @relation(fields: [watchId], references: [id], onDelete: Cascade)
}

// Lightweight activity stream powering daily digests / morning messages /
// "are they online today" approximation.
model ActivityEvent {
  id          String   @id @default(cuid())
  candidateId String?
  userId      String?
  trialId     String?
  type        String // post_observed | checkin_reply | submission | online_seen | morning_sent | digest_sent
  payload     String?
  createdAt   DateTime @default(now())

  candidate Candidate? @relation(fields: [candidateId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 3 — Account inventory & access tiers
// ─────────────────────────────────────────────────────────────────────────────

// A social account in the inventory (belongs to a model/creator). VAs are given
// access to accounts via AccessGrant; warm-status tracks the account lifecycle.
model Account {
  id        String   @id @default(cuid())
  platform  String // x | instagram | tiktok | reddit | onlyfans | other
  handle    String
  label     String?
  creatorId String?
  status    String   @default("warming") // warming | active | limited | suspended | banned | retired
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator Creator?      @relation(fields: [creatorId], references: [id])
  grants  AccessGrant[]

  @@index([creatorId])
}

// A VA's access to an account. Revoking sets status=revoked + revokedAt (the
// one-click offboard revokes every active grant a user holds).
model AccessGrant {
  id        String    @id @default(cuid())
  accountId String
  userId    String
  status    String    @default("active") // active | revoked
  note      String?
  grantedAt DateTime  @default(now())
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 4 — Training gate: a per-role reading module + auto-graded quiz that
// gates the trial. Passing (>= passPct) auto-advances the candidate to
// TRIAL_READY (which creates the trial + sends the brief).
// ─────────────────────────────────────────────────────────────────────────────
model TrainingModule {
  id        String   @id @default(cuid())
  roleId    String   @unique
  title     String
  content   String // the reading material (markdown-ish plain text)
  questions String   @default("[]") // JSON: [{prompt, options:[string], answer:number}]
  passPct   Int      @default(80)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role     Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  attempts QuizAttempt[]
}

model QuizAttempt {
  id            String   @id @default(cuid())
  moduleId      String
  candidateId   String
  applicationId String?
  score         Int // 0–100
  passed        Boolean  @default(false)
  answers       String   @default("[]") // JSON: number[] of chosen option indices
  createdAt     DateTime @default(now())

  module    TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  candidate Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@index([candidateId])
}
